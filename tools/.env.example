# LLM Configuration for build_graph.py
# Copy this file to .env and set your preferred provider

# ==============================
# Choose your LLM provider
# ==============================
# Options: claude, openai, ollama
LLM_PROVIDER=claude

# ==============================
# Claude (default)
# ==============================
# Reads from ~/.config/anthropic/config.json by default
# Or set explicitly:
# ANTHROPIC_API_KEY=sk-ant-xxxxx
# LLM_MODEL=claude-haiku-4-5-20251001  # or claude-3-5-haiku-20241022

# ==============================
# OpenAI
# ==============================
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-xxxxx
# LLM_MODEL=gpt-4o-mini  # or gpt-4o, gpt-3.5-turbo

# ==============================
# Ollama (local models)
# ==============================
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://localhost:11434  # optional, default is localhost:11434
# LLM_MODEL=llama3.2  # or qwen2.5, mistral, etc.

# ==============================
# OpenAI-compatible endpoints
# ==============================
# For vLLM, LocalAI, text-generation-webui, etc.
# LLM_PROVIDER=openai
# LLM_BASE_URL=http://localhost:8000/v1
# OPENAI_API_KEY=sk-xxxxx  # may not be needed for local
# LLM_MODEL=qwen2.5
